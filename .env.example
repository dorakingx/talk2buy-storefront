# Talk2Buy runs fully in demo mode without any keys below.
# Add keys for live ElevenLabs voice and Stripe Checkout.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (optional — demo checkout used when missing)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ElevenLabs (optional — browser voice fallback when missing)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# OpenAI (optional — richer assistant replies)
OPENAI_API_KEY=
